{
  "$schema": "https://unpkg.com/knip@next/schema.json",
  "project": ["**/*.ts", "**/*.tsx"],
  "ignore": ["node_modules/**", "dist/**"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "files": "warn",
    "dependencies": "warn",
    "unlisted": "error",
    "exports": "warn",
    "types": "warn"
  }
}
